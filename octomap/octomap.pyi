    def updateInnerOccupancy(self) -> None: ...
    def useBBXLimit(self, enable: bool) -> None: ...
    def volume(self) -> float: ...
    def expandNode(self, node: ColorOcTreeNode) -> None: ...
    def createNodeChild(
